# St. Louis Fed FRED API key (free): https://fred.stlouisfed.org/docs/api/api_key.html
# Used only by the dev server proxy (src/setupProxy.js) — not bundled into the client.
FRED_API_KEY=

# Optional: full base URL for production builds that proxy FRED (e.g. Netlify function).
# Example: https://your-site.netlify.app/.netlify/functions/fred
# Leave unset when using npm start with FRED_API_KEY above.
# REACT_APP_FRED_PROXY_URL=
